# Copy to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Yandex Cloud folder ID to list and manage resources in
FOLDER_ID=b1g0abc123def456

# Path to a Service Account JSON key file (downloaded from YC Console or yc CLI)
# The SA must have roles: compute.admin, mdb.admin, alb.admin, load-balancer.admin, k8s.admin
YC_SA_KEY_FILE=~/.config/yc/sa-key.json

# Resource types to include in the local Rundeck project (comma-separated)
# Supported: compute-instance, managed-postgresql, managed-kubernetes,
#            managed-kafka, network-load-balancer, application-load-balancer
RESOURCE_TYPES=compute-instance
